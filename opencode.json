{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/quality-bar.md",
    ".second-brain/RESOLVER.md",
    ".second-brain/schema.md",
    ".second-brain/projects/vibe-coding-dojo.md",
    ".second-brain/sessions/current-session.md"
  ],
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "secrets/**": "deny"
    },
    "edit": "ask",
    "bash": {
      "*": "ask",
      "python3 scripts/check_repo.py*": "allow",
      "python3 scripts/security_review.py*": "allow",
      "python3 scripts/consistency_check.py*": "allow",
      "python3 scripts/tool_doctor.py*": "allow",
      "python3 scripts/ai_coach.py*": "allow",
      "python3 -m dojo_app.maze_game*": "allow",
      "python3 scripts/verify_ai_tools.py*": "allow",
      "python3 scripts/setup_codex_devnet.py*": "allow",
      "python3 scripts/start_codex_model_adapter.py*": "allow",
      "python3 scripts/devnet_codex_shim.py*": "allow",
      "python3 scripts/setup_opencode_devnet.py*": "allow",
      "python3 scripts/start_opencode_model_adapter.py*": "allow",
      "python3 scripts/defenseclaw_skill_demo.py*": "allow",
      "python3 scripts/agent_compare.py*": "ask",
      "python3 scripts/agent_code_task.py*": "ask",
      "python3 scripts/first_agent_result.py*": "ask",
      "./scripts/install_ai_tools.sh*": "ask",
      "./scripts/install_defenseclaw_cli.sh*": "ask",
      "git status*": "allow",
      "rm *": "deny",
      "curl *": "ask"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  }
}
