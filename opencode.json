{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "docs/quality-bar.md"
  ],
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "secrets/**": "deny"
    },
    "edit": {
      "*": "ask"
    },
    "bash": {
      "*": "ask",
      "python3 scripts/quality_gate.py*": "allow",
      "python3 scripts/security_review.py*": "allow",
      "python3 scripts/consistency_check.py*": "allow",
      "python3 scripts/tool_doctor.py*": "allow",
      "python3 scripts/ai_coach.py*": "allow",
      "git status*": "allow",
      "rm *": "deny",
      "curl *": "ask"
    },
    "webfetch": "ask",
    "websearch": "ask",
    "external_directory": "ask",
    "doom_loop": "ask"
  }
}

