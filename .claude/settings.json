{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python3 scripts/quality_gate.py*)",
      "Bash(python3 scripts/security_review.py*)",
      "Bash(python3 scripts/consistency_check.py*)",
      "Bash(python3 scripts/tool_doctor.py*)",
      "Bash(python3 scripts/ai_coach.py*)",
      "Bash(git status*)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(curl *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf *)"
    ]
  }
}

